#!/usr/bin/env sh
set -eu

before_diff_file="$(mktemp)"
after_diff_file="$(mktemp)"

cleanup() {
	rm -f "$before_diff_file" "$after_diff_file"
}

trap cleanup EXIT

git diff --name-only -- '*.dart' | sort > "$before_diff_file"

echo "[pre-commit] verify formatting"
dart format .

git diff --name-only -- '*.dart' | sort > "$after_diff_file"

new_diff_files="$(comm -13 "$before_diff_file" "$after_diff_file")"

if [ -n "$new_diff_files" ]; then
	echo "[pre-commit] Dart files were reformatted. Review and stage the changes, then commit again."
	printf '%s\n' "$new_diff_files"
	exit 1
fi

echo "[pre-commit] analyze"
dart analyze --fatal-warnings
